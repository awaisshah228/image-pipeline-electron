  {
    "type": "webcam_capture",
    "display_name": "Webcam / Stream Capture",
    "description": "Capture frames from webcam or video stream URL. Supports live YOLO detection on each frame.",
    "icon": "Video",
    "category": "computer_vision",
    "inputs": [
      {
        "name": "source",
        "display_name": "Source",
        "type": "dropdown",
        "required": true,
        "show": true,
        "options": ["Webcam", "Stream URL"],
        "value": "Webcam",
        "info": "Select webcam for local camera or Stream URL for HLS/MJPEG streams."
      },
      {
        "name": "stream_url",
        "display_name": "Stream URL",
        "type": "str",
        "required": false,
        "show": true,
        "placeholder": "http://camera-ip/stream or .m3u8 URL",
        "info": "URL for HLS (.m3u8), MJPEG, or MP4 stream. Only used when Source is 'Stream URL'."
      },
      {
        "name": "capture_fps",
        "display_name": "Capture FPS",
        "type": "int",
        "required": true,
        "show": true,
        "value": 30,
        "info": "How many frames per second to capture and process. Lower = less CPU. Max 30."
      },
      {
        "name": "max_frames",
        "display_name": "Max Frames",
        "type": "int",
        "required": true,
        "show": true,
        "value": 0,
        "info": "Stop after this many frames. Set 0 for continuous (manual stop)."
      }
    ],
    "outputs": [
      { "name": "image", "display_name": "Current Frame", "types": ["Image"] },
      { "name": "frames", "display_name": "All Frames", "types": ["ImageList"] },
      { "name": "count", "display_name": "Frame Count", "types": ["Number"] }
    ]
  },
