  {
    "type": "cascade_detect",
    "display_name": "Cascade Detector",
    "description": "Detect objects using a custom Haar/LBP cascade XML. Provide a URL to any cascade file.",
    "icon": "Scan",
    "category": "computer_vision",
    "inputs": [
      {
        "name": "image",
        "display_name": "Image",
        "type": "str",
        "required": true,
        "show": false,
        "input_types": ["Image"]
      },
      {
        "name": "cascade_url",
        "display_name": "Cascade XML URL",
        "type": "str",
        "required": true,
        "show": true,
        "placeholder": "https://raw.githubusercontent.com/.../haarcascade_eye.xml",
        "info": "URL to a Haar or LBP cascade XML file"
      },
      {
        "name": "label",
        "display_name": "Label",
        "type": "str",
        "required": true,
        "show": true,
        "value": "object",
        "placeholder": "eye"
      },
      {
        "name": "scale_factor",
        "display_name": "Scale Factor",
        "type": "float",
        "required": true,
        "show": true,
        "value": 1.1,
        "info": "Image scale factor for multi-scale detection (1.01-1.5)"
      },
      {
        "name": "min_neighbors",
        "display_name": "Min Neighbors",
        "type": "int",
        "required": true,
        "show": true,
        "value": 3,
        "info": "Minimum neighbor detections to keep (higher = fewer false positives)"
      }
    ],
    "outputs": [
      { "name": "image", "display_name": "Annotated", "types": ["Image"] },
      { "name": "count", "display_name": "Count", "types": ["Number"] },
      { "name": "objects", "display_name": "Objects", "types": ["ImageList"] }
    ]
  },
